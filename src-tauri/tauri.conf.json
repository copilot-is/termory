{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Termory",
  "mainBinaryName": "Termory",
  "version": "0.1.0",
  "identifier": "is.chats.termory",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Termory",
        "width": 1240,
        "height": 820,
        "minWidth": 980,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
